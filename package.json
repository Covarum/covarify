{
  "name": "covarify",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node --experimental-strip-types scripts/verify-kms-oidc.ts && node --experimental-strip-types scripts/verify-waitlist-read.ts && node scripts/verify-cron-live.mjs && node --experimental-strip-types scripts/verify-plaid-production-env.ts && next build",
    "start": "next start",
    "test:early-access": "node --experimental-strip-types --test --test-isolation=none tests/early-access-route.test.mjs",
    "test:plaid-production": "node --conditions=react-server --experimental-strip-types --test --test-force-exit --test-isolation=none tests/plaid-production.test.mjs",
    "test:intelligence": "node --experimental-strip-types --test --test-isolation=none tests/money-picture-intelligence.test.mjs",
    "test": "pnpm run test:early-access && pnpm run test:plaid-production && pnpm run test:intelligence",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-kms": "^3.1090.0",
    "@radix-ui/react-slot": "latest",
    "@supabase/ssr": "^0.12.3",
    "@supabase/supabase-js": "^2.110.7",
    "@vercel/oidc-aws-credentials-provider": "^3.3.0",
    "class-variance-authority": "latest",
    "clsx": "latest",
    "framer-motion": "latest",
    "lucide-react": "latest",
    "next": "16.2.9",
    "plaid": "^43.0.0",
    "react": "latest",
    "react-dom": "latest",
    "react-plaid-link": "^4.1.1",
    "resend": "^6.17.2",
    "tailwind-merge": "latest"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "^9.39.1",
    "eslint-config-next": "16.2.9",
    "supabase": "^2.109.1",
    "tailwindcss": "latest",
    "typescript": "6.0.3"
  }
}
