# Server-only Resend configuration. Add real values in Vercel Project Settings.
RESEND_API_KEY=
EARLY_ACCESS_NOTIFY_EMAIL=
EARLY_ACCESS_FROM_EMAIL=
EARLY_ACCESS_REPLY_TO_EMAIL=

# Supabase. The service-role key is server-only and must never use NEXT_PUBLIC_.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
COVARIFY_PUBLIC_SIGNUPS_ENABLED=false

# Plaid server-only placeholders. Never use NEXT_PUBLIC_ for any Plaid secret.
PLAID_CLIENT_ID=
PLAID_SANDBOX_SECRET=
PLAID_PRODUCTION_SECRET=
PLAID_ENV=sandbox
PLAID_PRODUCTS=transactions
PLAID_COUNTRY_CODES=US
PLAID_CLIENT_NAME=Covarify
PLAID_WEBHOOK_URL=https://www.covarify.com/api/plaid/production/webhook
PLAID_REDIRECT_URI=https://www.covarify.com/connect/oauth

# Production Link remains unavailable until auth, persistence, encryption,
# consent, deletion, and verified-webhook adapters pass completion review.
PLAID_PRODUCTION_CONNECTIONS_ENABLED=false
PLAID_PRODUCTION_ALLOWED_USER_IDS=

# Vercel Cron transaction worker. Keep disabled until migrations, KMS, and the
# Production canary pass. CRON_SECRET must be a high-entropy server-only value.
PLAID_SYNC_WORKER_ENABLED=false
CRON_SECRET=

# Production AWS KMS. Credentials use the AWS SDK default credential chain.
PLAID_KMS_PROVIDER=aws
PLAID_KMS_KEY_ID=alias/covarify-production-plaid-tokens
AWS_REGION=us-east-1
AWS_ROLE_ARN=arn:aws:iam::386324384243:role/CovarifyPlaidKmsRuntime
